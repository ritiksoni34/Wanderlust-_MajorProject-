<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>
<body>
    <h3>edit your listings</h3>
    <form method="POST" action="/listings/<%= listing.id %>?_method=PUT" >
        <input type="text" value="<%= listing.title %>" name="listing[title]">
        <br>
        <br>
        <input type="text" value="<%= listing.description %>" name="listing[description]">
        <br>
        <br>
        <input type="number" value="<%= listing.price %>" min="0" name="listing[price]">
        <br>
        <br>
        <input type="text" value="<%= listing.location %>" name="listing[location]">
        <br>
        <br>
        <input type="text" value="<%= listing.country %>" name="listing[country]">
        <br>
        <br>
        <button>create</button>
    </form>
</body>
</html>