<% layout("/layouts/bieloer") %>
<style>
a{
    text-decoration: none;
    font-weight:700;
    color:rgb(255, 0, 183)
}
li{
    font-weight:900;
}



button {
  border: 4px solid;
  border-image-source: linear-gradient(45deg, #e90000, #010df2);
  border-image-slice: 1; /* Required to make the gradient visible across the border */
}
</style>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-3">
            <h3>.All listings </h3>
        </div>

        <div class="col-6 offset-3 show-card">
            <div class="card">
                <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="">
                <div class="card-body">
                <b><%= listing.title %></b>
                <br>
                <%= listing.description %> 
                <br>
                ₹ <%= listing.price.toLocaleString("en-IN") %>
                <br>
                <%= listing.location %> 
                <br>
                <%= listing.location %> 
                <br>
                <%= listing.country %>

            </div>
        </div>
        </div>
        <br>
        
    </div>
    <div class="btns">
            <a href="/listings/<%= listing.id%>/eidtis" class="btn btn-dark newbtn col-1 offset-3">Edit</a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button type="submit" class="btn btn-dark offset-4">Delete</button>
        </form>
        </div>
</body>
